<script setup lang="ts">
// 侧边栏底部用户卡片：动态显示当前登录用户，提供登出按钮
import { useAuth } from '~/composables/useAuth'

const { user, logout } = useAuth()

// 显示名优先 nickname，其次 username，最后兜底「管理员」
const displayName = computed(() => user.value?.nickname || user.value?.username || '管理员')
// 头像取名字首字（兜底 M）
const avatarChar = computed(() => displayName.value.charAt(0).toUpperCase())

function handleLogout() {
  logout()
  navigateTo('/login')
}
</script>

<template>
  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="sidebar-user-avatar">{{ avatarChar }}</div>
      <div class="sidebar-user-info">
        <div class="sidebar-user-name">{{ displayName }}</div>
        <div class="sidebar-user-role">创作者</div>
      </div>
      <button
        class="sidebar-user-logout"
        title="退出登录"
        @click="handleLogout"
      >
        <AppIcon name="logout" />
      </button>
    </div>
  </div>
</template>

