# 墨语 AI 小说创作平台 - 环境变量配置
# 复制此文件为 .env 并修改对应值

# ===== 应用 =====
MOYU_APP_NAME=墨语 AI 小说创作平台
MOYU_DEBUG=false
# ⚠️ 生产环境必须修改！用 openssl rand -hex 32 生成
MOYU_SECRET_KEY=change-this-to-a-random-secret-key

# ===== 数据库 =====
# Docker 部署时用 SQLite（默认），也可换 PostgreSQL
MOYU_DATABASE_URL=sqlite+aiosqlite:///./data/moyu.db

# ===== AI 模型配置（OpenAI 兼容）=====
# 支持 OpenAI / DeepSeek / Moonshot / 智谱 / 自建中转等所有 OpenAI 兼容接口
MOYU_AI_BASE_URL=https://api.openai.com/v1
MOYU_AI_API_KEY=sk-your-api-key-here
MOYU_AI_MODEL=gpt-4o
MOYU_AI_TEMPERATURE=0.85
MOYU_AI_TOP_P=0.9
MOYU_AI_MAX_TOKENS=4096

# ===== 章节生成参数 =====
MOYU_CHAPTER_DEFAULT_WORDS=2500
MOYU_CHAPTER_MIN_WORDS=2000
MOYU_CHAPTER_MAX_WORDS=3500

# ===== 服务器 =====
MOYU_HOST=0.0.0.0
MOYU_PORT=8000

# ===== 前端 =====
# Nuxt 公开 API 地址（客户端用）
NUXT_PUBLIC_API_BASE=http://localhost:8000
# Nuxt 服务端 API 地址（SSR 用，Docker 内用容器名）
NUXT_API_BASE=http://backend:8000

# ===== 本地 Embedding 模型（记忆向量检索用）=====
# 模型: BAAI/bge-small-zh-v1.5（512维，中文专用，~100MB）
# Docker 中通过 Dockerfile 预下载 + volume 持久化缓存
# 首次启动会自动下载，之后本地运行零 API 成本
# 如果网络不好导致下载失败，向量检索会自动回退到 API 模式
EMBEDDING_CACHE_DIR=~/.cache/fastembed
